{
  "name": "langtrace-vscode",
  "displayName": "LangTrace",
  "description": "Unofficial LangSmith client for VS Code - view traces, runs, and projects without leaving your editor",
  "version": "0.0.1",
  "publisher": "community",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [{
        "id": "langtrace",
        "title": "LangTrace",
        "icon": "media/icon.svg"
      }]
    },
    "views": {
      "langtrace": [
        { "id": "langtrace.projects", "name": "Projects" },
        { "id": "langtrace.runs", "name": "Runs" }
      ]
    },
    "commands": [
      { "command": "langtrace.setApiKey", "title": "LangTrace: Set API Key" },
      { "command": "langtrace.clearApiKey", "title": "LangTrace: Clear API Key" },
      { "command": "langtrace.refresh", "title": "LangTrace: Refresh", "icon": "$(refresh)" },
      { "command": "langtrace.openInBrowser", "title": "LangTrace: Open in Browser", "icon": "$(link-external)" }
    ],
    "menus": {
      "view/title": [
        {
          "command": "langtrace.refresh",
          "when": "view == langtrace.projects",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "LangTrace",
      "properties": {
        "langtrace.pollInterval": {
          "type": "number",
          "default": 30,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        },
        "langtrace.maxRuns": {
          "type": "number",
          "default": 50,
          "description": "Maximum number of runs to fetch per project"
        },
        "langtrace.baseUrl": {
          "type": "string",
          "default": "https://api.smith.langchain.com",
          "description": "LangSmith API base URL (change for self-hosted instances)"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "esbuild": "^0.20.0"
  }
}
